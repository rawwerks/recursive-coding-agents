#!/usr/bin/env sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
should_remind=0

while read -r local_ref local_sha remote_ref remote_sha; do
	case "$remote_ref" in
		refs/heads/main)
			# Ignore branch deletion pushes.
			if [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
				should_remind=1
			fi
			;;
	esac
done

if [ "$should_remind" -eq 1 ]; then
	cat >&2 <<EOF

Deploy reminder: pushing to main does not automatically publish the site.
After the push lands, deploy the current web build with:

  $repo_root/scripts/deploy-web.sh

For a no-upload check first:

  $repo_root/scripts/deploy-web.sh --dry-run

EOF
fi

exit 0
